rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.token.email in ["wilkersonmes@gmail.com", "jamillefernanda_@hotmail.com"] &&
        request.auth.token.email_verified == true;
    }
  }
}
