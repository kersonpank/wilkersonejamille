# =============================================================================
# VARIÁVEIS DE BUILD-TIME
# Estas precisam estar disponíveis no momento do "docker build" ou "npm run build"
# =============================================================================

# Chave PÚBLICA do Mercado Pago (aparece no frontend/bundle)
# Painel MP → Suas integrações → Credenciais → Chave pública
VITE_MERCADOPAGO_PUBLIC_KEY="APP_USR-sua-chave-publica-producao"


# =============================================================================
# VARIÁVEIS DE RUNTIME
# Injetadas pelo Docker / Railway / Portainer em tempo de execução
# =============================================================================

# URL pública do app (sem barra no final)
# Usado para montar o notification_url do webhook do Mercado Pago
APP_URL="https://listasonhos.seudominio.com"

# Access Token SECRETO do Mercado Pago (nunca expor no frontend)
# Painel MP → Suas integrações → Credenciais → Access token
MERCADOPAGO_ACCESS_TOKEN="APP_USR-seu-access-token-producao"

# Service Account do Firebase (JSON convertido em base64)
# Passos para gerar:
#   1. Google Cloud Console → IAM → Service Accounts → Criar conta de serviço
#   2. Papel: "Firebase Admin SDK Administrator Service Agent" ou "Cloud Datastore User"
#   3. Criar chave JSON → Baixar o arquivo
#   4. Converter: base64 -i service-account.json | tr -d '\n'
#   5. Colar o resultado abaixo
FIREBASE_SERVICE_ACCOUNT="base64_do_json_da_service_account"

# API Google Gemini — fallback de extração de produtos quando scraping não resolve (backend only, FREE tier: 1500 req/dia)
# Obter em: https://aistudio.google.com/app/apikey
# Opcional: sem esta key a extração via HTML puro ainda funciona para a maioria dos sites
GEMINI_API_KEY="sua_gemini_api_key_aqui"

# Porta do servidor (opcional, padrão: 3000)
# PORT=3000
